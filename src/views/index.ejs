<%- include('partials/header') %>

    <section class="hero-section">
        <div class="hero-content">
            <h2>Velkomin á Uppskriftavefinn</h2>
            <p>Hér getur þú fundið spennandi nýjar uppskriftir eða deilt þínum eigin með öðrum. Eldamennska hefur aldrei
                verið skemmtilegri!</p>
            <a href="/uppskriftir" class="btn-primary">Skoða Uppskriftir</a>
        </div>
    </section>

    <section class="featured">
        <h3>Úrval vikunnar</h3>
        <div class="card-grid">
            <!-- Nýtt efni: Byrjum EJS lúppu til að keyra yfir öll gögnin úr db -->
            <% if (recipes && recipes.length> 0) { %>
                <% recipes.forEach(recipe=> { %>
                    <div class="recipe-card">
                        <!-- Sýni enga alvöru mynd eins og er, en gæti notað <%= recipe.image_url %> í framtíðinni -->
                        <div class="card-img placeholder-img"></div>
                        <div class="card-info">
                            <!-- Prentar úr database columunum 'title' og 'time_minutes' -->
                            <h4>
                                <%= recipe.title %>
                            </h4>
                            <p>Tími: <%= recipe.time_minutes %> mín</p>
                            <a href="/uppskriftir/<%= recipe.id %>" style="color: #ff6b6b; font-weight: 600; text-decoration: none; display: inline-block; margin-top: 15px;">
                                Skoða nánar →
                            </a>
                        </div>
                    </div>
                    <% }) %>
                        <% } else { %>
                            <div class="recipe-card">
                                <div class="card-info">
                                    <h4>Engar uppskriftir fundust</h4>
                                    <p>Bættu við uppskriftum í gagnagrunninn.</p>
                                </div>
                            </div>
                            <% } %>
                                <!-- Nýtt efni: Lúppu lýkur -->
        </div>
    </section>

    <%- include('partials/footer') %>